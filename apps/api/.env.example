# Port for the Express server to listen on (Default: 3001)
PORT=3001

# Environment mode ('development' or 'production')
NODE_ENV=development

# Comma-separated list of allowed origins for CORS in production
# ALLOWED_ORIGINS=https://doki.com,https://app.doki.com

# Secret key used for signing JWTs (REQUIRED)
JWT_SECRET=your_super_secret_jwt_key_here

# Set to true to bypass Gemini API and return a mock classification structure
SIMULATE_AI=false

# API Key for Google Gemini (REQUIRED unless SIMULATE_AI=true)
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite Database URL (Prisma connection string)
DATABASE_URL="file:./dev.db"
